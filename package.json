{
  "name": "mysafeops",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run verify:blog && node scripts/generate-sitemap.mjs && node scripts/generate-blog-rss.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "stripe:seed-prices": "node scripts/stripe-seed-prices.mjs",
    "stripe:retry-webhooks": "node scripts/stripe-retry-webhook-failures.mjs",
    "billing:doctor": "node scripts/billing-doctor.mjs",
    "test:e2e": "playwright test",
    "test:e2e:blog": "playwright test tests/e2e/blog.spec.js",
    "test:e2e:landing": "playwright test tests/e2e/landing.spec.js",
    "test:e2e:billing": "playwright test tests/e2e/billing.spec.js",
    "test:e2e:ui": "playwright test --ui",
    "env:check": "node scripts/env-doctor.mjs",
    "verify:blog": "node scripts/verify-blog.mjs",
    "lint": "eslint \"src/**/*.{js,jsx}\" \"tests/**/*.{js,jsx}\" \"scripts/**/*.{js,mjs}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx}\" \"tests/**/*.{js,jsx}\" \"scripts/**/*.{js,mjs}\" --fix",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"tests/**/*.{js,jsx}\" \"scripts/**/*.{js,mjs}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx}\" \"tests/**/*.{js,jsx}\" \"scripts/**/*.{js,mjs}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@supabase/supabase-js": "^2.102.1",
    "dompurify": "^3.4.0",
    "html2canvas": "^1.4.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.468.0",
    "marked": "^18.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^16.4.7",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.8.3",
    "stripe": "^17.5.0",
    "vite": "^6.0.3",
    "vitest": "^3.0.5"
  }
}
