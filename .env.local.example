# =============================================================================
# MySafeOps — copy this file to `.env.local` and fill in values (never commit `.env.local`).
# UI language: English. Primary market: United Kingdom (GB).
# =============================================================================

# --- Optional: app metadata (for future locale / defaults) ---
VITE_APP_REGION=GB
VITE_APP_LOCALE=en-GB

# --- Supabase (auth + optional JSON backup sync) ---
# Dashboard: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=
#
# Google sign-in: Dashboard → Authentication → Providers → Google (Client ID + Secret from Google Cloud Console).
# Keep these as server-only deployment vars (no VITE_ prefix). They are NOT used by the browser app directly.
# Use them when configuring Supabase/infra and never expose the secret in frontend code.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Authentication → URL Configuration → Redirect URLs must include your app origins, e.g.:
#   http://localhost:5173/login
#   http://localhost:5173/reset-password
#   http://localhost:5173/app
#   https://your-production-domain/login
#   https://your-production-domain/reset-password
#   https://your-production-domain/app

# --- Anthropic (AI RAMS, toolbox talks, photo hazard) ---
# WARNING: any VITE_* value is visible in the browser bundle. Use only for local/dev,
# or proxy calls through your own backend in production.
VITE_ANTHROPIC_API_KEY=
# Optional — default is a recent Sonnet if unset
VITE_ANTHROPIC_MODEL=

# --- Cloudflare R2 object storage (recommended setup) ---
# Do NOT put R2 secret keys in VITE_* variables. Deploy the Worker in `cloudflare/workers/r2-upload`
# and point the app at its public URL.
#
# Base URL of the Worker (no trailing slash), e.g. https://mysafeops-r2-upload.your-subdomain.workers.dev
VITE_STORAGE_API_URL=
#
# Shared secret: must match the Worker's UPLOAD_TOKEN secret (wrangler secret put UPLOAD_TOKEN).
# Sent as header X-Upload-Token from the browser.
VITE_STORAGE_UPLOAD_TOKEN=
#
# Optional: public read URL for objects (custom domain or R2 public bucket URL), no trailing slash.
# If set, the app will show a direct link after upload: {VITE_R2_PUBLIC_BASE_URL}/{object-key}
VITE_R2_PUBLIC_BASE_URL=

# --- Optional weather provider for RAMS "Fetch weather" ---
# If unset, the app uses keyless Open-Meteo.
VITE_OPENWEATHER_API_KEY=

# --- Stripe (subscriptions) — do NOT put secret keys in Vite ---
# Local/dev only: STRIPE_SECRET_KEY in this file for `npm run stripe:seed-prices` (never commit).
# Production: store secrets in Supabase Dashboard → Edge Functions → Secrets (see README).
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# After seeding, paste Price ids into Supabase secrets:
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_TEAM=price_...
# STRIPE_PRICE_BUSINESS=price_...
# SITE_URL=https://your-domain.com
# Publishable key is optional for Checkout redirect (not used by the app today). If you add Elements later, use VITE_STRIPE_PUBLISHABLE_KEY=pk_...
