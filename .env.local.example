# =============================================================================
# MySafeOps — copy to `.env.local` (gitignored). Never commit `.env.local`.
# Run `npm run env:check` after edits.
# Mirror VITE_* names in Vercel: Project → Settings → Environment Variables.
# =============================================================================
#
# SECURITY
# - Any VITE_* value is embedded in the browser bundle — never production secrets there.
# - VAPID_PRIVATE_KEY belongs ONLY in Supabase → Edge Functions → Secrets (not here).
# - Stripe live keys: use sk_test_* locally; production → Supabase Edge secrets only.
# =============================================================================

# --- Optional app metadata ---
VITE_APP_REGION=GB
VITE_APP_LOCALE=en-GB

# Public support inbox (shown in UI / mailto). Not secret.
VITE_SUPPORT_EMAIL=support@mysafeops.com
# IT-only hints (Supabase redirect URLs, .env keys) on /login and Cloud account — off in production unless true
# VITE_SHOW_LOGIN_ADMIN_HINTS=true
# Platform owner email(s) for Superadmin + unlimited billing UX — must match `supabase/migrations/*superadmin*` RPC checks if you migrate off the default.
# VITE_PLATFORM_OWNER_EMAIL=mysafeops@gmail.com
# Optional string shown in Help → about (falls back to package.json version)
# VITE_APP_VERSION=

# --- Supabase (auth + optional backup sync) ---
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Google OAuth: configure Client ID + Secret in Supabase → Authentication → Providers → Google.
# Do not prefix with VITE_ — the browser app does not read these; Supabase does.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
#
# Authentication → URL Configuration → Redirect URLs (add each host you use):
#   http://localhost:5173/login
#   http://localhost:5173/reset-password
#   http://localhost:5173/app
#   https://your-production-domain/login
#   https://your-production-domain/reset-password
#   https://your-production-domain/app

# --- Web Push (public key only in frontend) ---
# Must match Supabase Edge secret VAPID_PUBLIC_KEY. Private key + VAPID_SUBJECT only in Supabase secrets.
VITE_VAPID_PUBLIC_KEY=

# --- Anthropic (AI RAMS, toolbox, photo hazard) ---
# VITE_ANTHROPIC_API_KEY is visible in the bundle — OK for local dev.
# Production (Vercel): set VITE_ANTHROPIC_PROXY_URL=/api/anthropic-messages and ANTHROPIC_API_KEY in Vercel env (not VITE_*).
# Optional shared secret: VITE_AI_PROXY_SECRET + AI_PROXY_SHARED_SECRET (same value).
VITE_ANTHROPIC_API_KEY=
# VITE_ANTHROPIC_PROXY_URL=/api/anthropic-messages
# VITE_AI_PROXY_SECRET=
VITE_ANTHROPIC_MODEL=
# Optional Web Vitals POST (default prod: /api/web-vitals)
# VITE_WEB_VITALS_URL=

# --- Cloudflare R2 (Worker: cloudflare/workers/r2-upload) ---
# Never put R2 account secret keys in VITE_*.
VITE_STORAGE_API_URL=
VITE_STORAGE_UPLOAD_TOKEN=
VITE_R2_PUBLIC_BASE_URL=

# --- Cloudflare D1 (Worker: cloudflare/workers/d1-api) — org JSON KV; see DOCS/D1_SETUP.md ---
# VITE_D1_API_URL=https://mysafeops-d1-api.<account>.workers.dev

# --- Optional: OpenWeather for RAMS "Fetch weather" (else keyless Open-Meteo) ---
VITE_OPENWEATHER_API_KEY=

# Optional: base URL for canonical blog links, sitemap, OG (no trailing slash). Default https://mysafeops.com/blog
# VITE_BLOG_POSTS_BASE_URL=https://mysafeops.com/blog
# Optional: public site origin for absolute OG image URLs (no trailing slash). Default https://mysafeops.com
# VITE_PUBLIC_SITE_URL=https://mysafeops.com

# In-app documentation hub path (default /docs) or full https URL for an external doc site
# VITE_PUBLIC_DOCS_PATH=/docs
# Service status: leave unset to use in-app /status, or set to e.g. https://status.mysafeops.com
# VITE_PUBLIC_STATUS_URL=

# Optional: browser error reporting (public DSN only)
# VITE_SENTRY_DSN=

# --- Stripe (CLI scripts + docs) — one block only; no duplicate keys ---
# Local: `npm run stripe:seed-prices` reads STRIPE_SECRET_KEY from the environment (dotenv loads .env.local).
# Production billing: STRIPE_* and SITE_URL in Supabase → Edge Functions → Secrets (see README).
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_TEAM=price_...
# STRIPE_PRICE_BUSINESS=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# SITE_URL=https://your-domain.com
# If you add Stripe.js in the browser later:
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
