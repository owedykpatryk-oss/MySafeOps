# Commit-safe template. For a full checklist, copy `.env.local.example` → `.env.local` (gitignored).

VITE_APP_REGION=GB
VITE_APP_LOCALE=en-GB

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Web Push: same public key as Supabase Edge secret VAPID_PUBLIC_KEY (never put the private key here).
# Supabase Dashboard → Edge Functions → Secrets: VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_SUBJECT (e.g. mailto:you@domain.com)
VITE_VAPID_PUBLIC_KEY=
# Google OAuth setup (Supabase provider):
# - Add Google Client ID/Secret in Supabase Dashboard (server-side only, never VITE_).
# - Add redirect URLs for each origin: /login, /reset-password, /app.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_MODEL=

# Cloudflare R2 (via Worker in cloudflare/workers/r2-upload — do not put R2 secret keys here)
VITE_STORAGE_API_URL=
VITE_STORAGE_UPLOAD_TOKEN=
VITE_R2_PUBLIC_BASE_URL=
