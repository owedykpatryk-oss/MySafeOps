# Commit-safe template. For a full checklist, copy `.env.local.example` → `.env.local` (gitignored).

VITE_APP_REGION=GB
VITE_APP_LOCALE=en-GB

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=
# Google OAuth: enable provider in Supabase; add /login and /app redirect URLs for each origin.

VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_MODEL=

# Cloudflare R2 (via Worker in cloudflare/workers/r2-upload — do not put R2 secret keys here)
VITE_STORAGE_API_URL=
VITE_STORAGE_UPLOAD_TOKEN=
VITE_R2_PUBLIC_BASE_URL=
