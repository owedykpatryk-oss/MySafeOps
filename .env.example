# Commit-safe template. Copy `.env.local.example` → `.env.local` for real values.
# Run `npm run env:check` to validate presence of common keys (no secrets printed).

VITE_APP_REGION=GB
VITE_APP_LOCALE=en-GB
# VITE_APP_VERSION=

# Public support address (embedded in bundle). Default: support@mysafeops.com
VITE_SUPPORT_EMAIL=support@mysafeops.com
# Show Supabase / .env setup hints on Login + Cloud account (off in production; dev always on)
# VITE_SHOW_LOGIN_ADMIN_HINTS=true
# Comma-separated JWT emails allowed as platform owner in the app (must match superadmin SQL if you change owner)
# VITE_PLATFORM_OWNER_EMAIL=mysafeops@gmail.com

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Web Push: VITE_VAPID_PUBLIC_KEY pairs with Supabase Edge secrets VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_SUBJECT
VITE_VAPID_PUBLIC_KEY=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Anthropic: local dev may use VITE_ANTHROPIC_API_KEY (exposed in bundle). Production: proxy + server secret.
VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_MODEL=
# Same-origin proxy (Vercel api/anthropic-messages.js). Set ANTHROPIC_API_KEY on Vercel (never VITE_*).
# VITE_ANTHROPIC_PROXY_URL=/api/anthropic-messages
# Optional shared secret (must match AI_PROXY_SHARED_SECRET on server):
# VITE_AI_PROXY_SECRET=
# AI_PROXY_SHARED_SECRET=

# Optional Web Vitals POST target (default in prod: /api/web-vitals). Override with full URL if needed.
# VITE_WEB_VITALS_URL=/api/web-vitals

VITE_STORAGE_API_URL=
VITE_STORAGE_UPLOAD_TOKEN=
VITE_R2_PUBLIC_BASE_URL=

# Cloudflare D1 API Worker — org-scoped JSON sync (see DOCS/D1_SETUP.md, cloudflare/workers/d1-api)
# VITE_D1_API_URL=https://mysafeops-d1-api.<account>.workers.dev

VITE_OPENWEATHER_API_KEY=

# Canonical base for blog article links on the landing grid (no trailing slash). Default: https://mysafeops.com/blog
# VITE_BLOG_POSTS_BASE_URL=

# Public site origin for OG images, sitemap, and RSS (no trailing slash). Default: https://mysafeops.com
# VITE_PUBLIC_SITE_URL=

# Optional browser error monitoring (public DSN only)
# VITE_SENTRY_DSN=
# VITE_PUBLIC_DOCS_PATH=/docs
# VITE_PUBLIC_STATUS_URL=
