# Supabase (Vercel: add same names in Project → Settings → Environment Variables)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Optional — Anthropic API for AI RAMS, toolbox talks, and photo hazard (browser exposes key; use only for local/dev).
VITE_ANTHROPIC_API_KEY=
# Optional model override (default: claude-sonnet-4-20250514)
VITE_ANTHROPIC_MODEL=
